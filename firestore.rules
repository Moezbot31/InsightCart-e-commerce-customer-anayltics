rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAnalyst() {
      return isAuthenticated() && getUserData().role == 'analyst';
    }

    function isExecutive() {
      return isAuthenticated() && getUserData().role == 'executive';
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role;
    }

    // Analysis Results
    match /analyses/{analysisId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated(); // Allow all authenticated users to create analyses
      allow update: if false; // Analyses are immutable records
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Custom Dashboards
    match /dashboards/{dashboardId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
